<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Top header bar -->
    <LinearLayout
        android:id="@+id/settings_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@color/surface_dark"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONFIGURATION"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.12" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ProgressBar
                android:id="@+id/progress_keys"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:progressTint="@color/crucix_cyan"
                android:progressBackgroundTint="@color/surface_border"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/tv_key_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 10 keys configured"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginStart="12dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Bottom action bar -->
    <LinearLayout
        android:id="@+id/action_bar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:background="@color/surface_dark"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <Button
            android:id="@+id/btn_clear_all"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLEAR"
            android:textColor="@color/status_red"
            android:textSize="12sp"
            android:minWidth="0dp" />

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

        <Button
            android:id="@+id/btn_copy_env"
            style="@style/CrucixButtonOutlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COPY .ENV"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_save"
            style="@style/CrucixButtonFilled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVE" />

    </LinearLayout>

    <!-- Scrollable settings content between header and action bar -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/settings_header"
        android:layout_above="@id/action_bar">

        <LinearLayout
            android:id="@+id/settings_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

    </androidx.core.widget.NestedScrollView>

</RelativeLayout>
